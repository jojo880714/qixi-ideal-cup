# Supabase — public (safe for client bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only, NEVER exposed to the client bundle.
# Used only inside app/api/* route handlers (Node runtime) for /stats aggregation.
SUPABASE_SERVICE_ROLE_KEY=

# Rate limiting (Upstash Redis). Required in production; without these,
# writes fall back to an in-memory limiter that only works within a single
# serverless instance and MUST NOT be relied on in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Base URL used to build absolute OG image / share links + metadataBase.
# Set to the production domain (start with the Vercel *.vercel.app URL; when a
# custom domain is added later, change ONLY this one value). Falls back to
# Vercel's per-deployment VERCEL_URL, then to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Signup link for the "報名實體聯誼活動" CTA on the result card (Design Spec
# signupUrl). Provided by the campaign partner — leave blank until confirmed;
# while blank, the CTA is hidden rather than linking nowhere.
NEXT_PUBLIC_SIGNUP_URL=
